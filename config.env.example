# Effira API credentials
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit it.

# From step 3 of Effira API key setup (keyId + secret from POST /me/api-keys)
EFFIRA_KEY_ID=
EFFIRA_KEY_SECRET=

# Your installation's asset ID in Effira's test environment
EFFIRA_ASSET_ID=69fc584c69510b39091a2b02

# Home Assistant local URL (no trailing slash)
HA_URL=http://homeassistant.local:8123

# HA long-lived access token
# Generate at: HA → Profile → Security → Long-lived access tokens
HA_TOKEN=

# --- Optional tuning ---

# NordPool sensor entity ID (default matches existing automations)
# NORDPOOL_ENTITY=sensor.nordpool_kwh_se3_sek_3_10_025

# GoodWe active power sensor (negative value = exporting to grid)
# GOODWE_ENTITY=sensor.goodwe_active_power

# Boost below this price (SEK/kWh incl. VAT+fees, default 1.0)
# CHEAP_PRICE_SEK=1.0

# Boost when solar export >= this (W, default 300)
# SOLAR_EXPORT_W=300
